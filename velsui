	local function hideKeybind()
		if not keybindPopupOpen then return end
		keybindPopupOpen = false
		keybindListening = false
		tween(keybindScale, 0.2, { Scale = 0 }, Enum.EasingStyle.Quart).Completed:Once(function()
			if not keybindPopupOpen then
				keybindPop.Visible = false
				keybindShade.Visible = false
			end
		end)
