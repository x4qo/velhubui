			}, { corner(10) })
		end
		table.insert(searchable, { Name = (label .. " " .. description):lower(), Object = row })
		table.insert(accentListeners, function(color)
			if enabled then control.BackgroundColor3 = color end
		end)

		local function flip()
			enabled = not enabled
			tween(control, 0.2, { BackgroundColor3 = enabled and C.Accent or C.Control })
			if style == "checkbox" then
				local markScale = mark:FindFirstChild("MarkScale")
				if enabled then
					mark.Rotation = -20
					markScale.Scale = 0.2
					control.Rotation = -7
					control.Size = UDim2.fromOffset(22, 22)
					checkShort.BackgroundTransparency = 1
					checkLong.BackgroundTransparency = 1
					tween(control, 0.28, { Rotation = 0, Size = UDim2.fromOffset(25, 25) }, Enum.EasingStyle.Back)
					tween(mark, 0.24, { Rotation = 0 })
					tween(checkShort, 0.16, { BackgroundTransparency = 0 })
					task.delay(0.06, function()
						if enabled then tween(checkLong, 0.18, { BackgroundTransparency = 0 }) end
					end)
					tween(markScale, 0.34, { Scale = 1 }, Enum.EasingStyle.Back)
				else
					tween(control, 0.18, { Rotation = 7, Size = UDim2.fromOffset(22, 22) }).Completed:Once(function()
						tween(control, 0.2, { Rotation = 0, Size = UDim2.fromOffset(25, 25) }, Enum.EasingStyle.Back)
					end)
					tween(mark, 0.18, { Rotation = 18 })
					tween(checkShort, 0.12, { BackgroundTransparency = 1 })
					tween(checkLong, 0.12, { BackgroundTransparency = 1 })
					tween(markScale, 0.18, { Scale = 0.15 }).Completed:Once(function()
						if not enabled then mark.Rotation = 0 end
					end)
				end
			else
				tween(mark, 0.25, {
					Position = enabled and UDim2.new(1, -13, 0.5, 0) or UDim2.new(0, 13, 0.5, 0),
				}, Enum.EasingStyle.Back)
			end
			if onChanged then task.spawn(onChanged, enabled) end
			if refreshKeybindHud then refreshKeybindHud() end
		end

		row.MouseButton1Click:Connect(function()
			haptic(0.16)
			flip()
		end)

		local handle = {
			Frame = row,
			Get = function() return enabled end,
			Set = function(_, on)
				if (on and true or false) ~= enabled then flip() end
			end,
			Flip = flip,
		}

		if keybindable then
			local controlWidth = style == "checkbox" and 25 or 43
			local function setState(on)
				if enabled ~= on then flip() end
			end
			local entry = {
				key = nil,
				mode = "Toggle",
				name = label,
				flip = flip,
				setState = setState,
				isOn = function() return enabled end,
			}
			table.insert(keybinds, entry)
			handle.Keybind = entry
			local gear = create("TextButton", {
				AnchorPoint = Vector2.new(1, 0.5),
