	local function dropdown(parent, order, o)
		local options = o.Options or {}
		local function labelOf(c) return type(c) == "table" and c[1] or c end
		local function valueOf(c) return type(c) == "table" and c[2] or c end

		local frame = create("Frame", {
			Size = UDim2.new(1, 0, 0, 43),
			BackgroundColor3 = Color3.fromRGB(40, 43, 49),
			BorderSizePixel = 0,
			ClipsDescendants = true,
			LayoutOrder = order,
			Parent = parent,
		}, { corner(11), stroke(C.Line) })
		local selected = create("TextButton", {
			Size = UDim2.new(1, 0, 0, 43),
			BackgroundTransparency = 1,
			Text = o.Default or o.Placeholder or (options[1] and labelOf(options[1])) or "Select",
			TextColor3 = C.Text,
			TextSize = 14,
			FontFace = Medium,
			TextXAlignment = Enum.TextXAlignment.Left,
			AutoButtonColor = false,
			ZIndex = 2,
			Parent = frame,
		}, { create("UIPadding", { PaddingLeft = UDim.new(0, 13), PaddingRight = UDim.new(0, 35) }) })
		local arrow = create("TextLabel", {
			AnchorPoint = Vector2.new(1, 0.5),
			Position = UDim2.new(1, -10, 0, 21),
			Size = UDim2.fromOffset(24, 24),
			BackgroundTransparency = 1,
			Text = "⌄",
			TextColor3 = C.Muted,
			TextSize = 18,
			ZIndex = 3,
			Parent = frame,
		})
		local list = create("Frame", {
			Position = UDim2.fromOffset(0, 48),
			Size = UDim2.new(1, -16, 0, 0),
			AutomaticSize = Enum.AutomaticSize.Y,
			BackgroundTransparency = 1,
			Parent = frame,
		}, {
			create("UIListLayout", { Padding = UDim.new(0, 4), SortOrder = Enum.SortOrder.LayoutOrder }),
			create("UIPadding", { PaddingLeft = UDim.new(0, 8) }),
		})

		local multi = o.Multi and true or false
		local rowStride = 34 + 4
		local listHeight = #options * rowStride
		local maxHeight = tonumber(o.MaxHeight)
		if maxHeight and maxHeight > 0 then
			listHeight = math.min(listHeight, maxHeight * rowStride)
		end
		local openHeight = 48 + listHeight + 6
		if maxHeight and maxHeight > 0 and #options > maxHeight then
			list.Size = UDim2.new(1, -16, 0, listHeight)
			list.AutomaticSize = Enum.AutomaticSize.None
		end
		local isOpen = false
		local currentValue = multi and {} or nil
		local setters = {}

		local function close()
			isOpen = false
			tween(arrow, 0.22, { Rotation = 0 })
			tween(frame, 0.28, { Size = UDim2.new(1, 0, 0, 43) }, Enum.EasingStyle.Quint)
		end
		local function refreshText()
			if multi then
				local picked = {}
				for _, c in ipairs(options) do
					if currentValue[valueOf(c)] then picked[#picked + 1] = labelOf(c) end
				end
				selected.Text = (#picked > 0) and table.concat(picked, ", ") or (o.Placeholder or "None")
			end
		end
		local function fire()
			if o.Flag then flags[o.Flag] = currentValue end
			if o.Callback then task.spawn(o.Callback, currentValue) end
		end

		for _, choice in ipairs(options) do
			local lbl, val = labelOf(choice), valueOf(choice)
			local _, setSel = dropdownOption(list, lbl, nil, function()
				if multi then
					currentValue[val] = (not currentValue[val]) or nil
					setters[val](currentValue[val] ~= nil)
					refreshText()
					fire()
				else
					selected.Text = lbl
					currentValue = val
					for _, fn in pairs(setters) do fn(false) end
					setters[val](true)
					close()
					fire()
				end
			end)
			setters[val] = setSel
		end

		if o.Default ~= nil then
			if multi then
				local defaults = type(o.Default) == "table" and o.Default or { o.Default }
				for _, d in ipairs(defaults) do
					for _, c in ipairs(options) do
						if labelOf(c) == d or valueOf(c) == d then
							currentValue[valueOf(c)] = true
							setters[valueOf(c)](true)
						end
					end
				end
				refreshText()
			else
				for _, c in ipairs(options) do
					if labelOf(c) == o.Default or valueOf(c) == o.Default then
						currentValue = valueOf(c)
						selected.Text = labelOf(c)
						setters[valueOf(c)](true)
					end
				end
			end
		elseif multi then
			refreshText()
		end
		if o.Flag then flags[o.Flag] = currentValue end

		selected.MouseButton1Click:Connect(function()
			haptic(0.1)
			isOpen = not isOpen
			tween(arrow, 0.24, { Rotation = isOpen and 180 or 0 })
			tween(frame, 0.34, { Size = UDim2.new(1, 0, 0, isOpen and openHeight or 43) }, Enum.EasingStyle.Back)
		end)
		table.insert(searchable, { Name = (o.Text or selected.Text):lower(), Object = frame })
		return {
			Frame = frame,
			Get = function() return currentValue end,
			Set = function(_, v)
				if multi then
					currentValue = {}
					local list2 = type(v) == "table" and v or { v }
					for _, fn in pairs(setters) do fn(false) end
					for _, d in ipairs(list2) do
						for _, c in ipairs(options) do
							if labelOf(c) == d or valueOf(c) == d then
								currentValue[valueOf(c)] = true
								setters[valueOf(c)](true)
							end
						end
					end
					refreshText()
					fire()
				else
					for _, c in ipairs(options) do
						if labelOf(c) == v or valueOf(c) == v then
							selected.Text = labelOf(c)
							currentValue = valueOf(c)
							for _, fn in pairs(setters) do fn(false) end
							setters[valueOf(c)](true)
							fire()
							break
						end
					end
				end
			end,
		}
	end

