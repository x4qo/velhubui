				BackgroundColor3 = enabled and C.Accent or C.Control,
				BorderSizePixel = 0,
				Parent = row,
			}, { corner(13) })
			mark = create("Frame", {
				AnchorPoint = Vector2.new(0.5, 0.5),
				Position = enabled and UDim2.new(1, -13, 0.5, 0) or UDim2.new(0, 13, 0.5, 0),
				Size = UDim2.fromOffset(19, 19),
				BackgroundColor3 = C.Text,
