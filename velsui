		if input.UserInputType ~= Enum.UserInputType.Keyboard or input.KeyCode == Enum.KeyCode.Unknown then
			return
		end
		if keybindListening and keybindEntry then
			if input.KeyCode ~= Enum.KeyCode.Escape then
				keybindEntry.key = input.KeyCode
			end
			keybindListening = false
			refreshKeyButton()
			if keybindEntry.onChanged then keybindEntry.onChanged() end
			if refreshKeybindHud then refreshKeybindHud() end
			return
		end
		if keybindPopupOpen or processed or UserInputService:GetFocusedTextBox() then return end
		for _, kb in ipairs(keybinds) do
			if kb.key == input.KeyCode then
				haptic(0.16)
				if kb.mode == "Hold" then kb.setState(true) else kb.flip() end
