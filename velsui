local function haptic(strength)
	task.spawn(function()
		pcall(function()
			if HapticService:IsVibrationSupported(Enum.UserInputType.Gamepad1) then
				HapticService:SetMotor(Enum.UserInputType.Gamepad1, Enum.VibrationMotor.Small, strength or 0.18)
				task.wait(0.035)
				HapticService:SetMotor(Enum.UserInputType.Gamepad1, Enum.VibrationMotor.Small, 0)
			end
		end)
	end)
end

local function tween(object, duration, properties, style)
	local result = TweenService:Create(
		object,
		TweenInfo.new(duration or 0.22, style or Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
		properties
	)
	result:Play()
	return result
end

local function merge(base, over)
	local t = {}
	for k, v in pairs(base) do t[k] = v end
	if over then for k, v in pairs(over) do t[k] = v end end
	return t
end

local function resolveSize(size, dw, dh)
	if typeof(size) == "UDim2" then
		return size.X.Offset, size.Y.Offset
	elseif type(size) == "table" then
		return size[1] or size.Width or dw, size[2] or size.Height or dh
	end
	return dw, dh
end

