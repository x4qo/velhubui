	local colorState = { h = 0, s = 1, v = 1, apply = nil, open = false }
	local function colorFromState()
		return Color3.fromHSV(colorState.h, colorState.s, colorState.v)
	end
	local function refreshColorPop()
		local col = colorFromState()
		svArea.BackgroundColor3 = Color3.fromHSV(colorState.h, 1, 1)
		svCursor.Position = UDim2.fromScale(colorState.s, 1 - colorState.v)
		hueCursor.Position = UDim2.fromScale(colorState.h, 0.5)
		colorPreview.BackgroundColor3 = col
		colorHexBox.Text = string.format("#%02X%02X%02X",
			math.floor(col.R * 255 + 0.5), math.floor(col.G * 255 + 0.5), math.floor(col.B * 255 + 0.5))
		if colorState.apply then colorState.apply(col) end
	end
	local function hideColor()
		if not colorState.open then return end
		colorState.open = false
		tween(colorScale, 0.2, { Scale = 0 }, Enum.EasingStyle.Quart).Completed:Once(function()
			if not colorState.open then
				colorPop.Visible = false
				colorShade.Visible = false
			end
		end)
	end
