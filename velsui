	local function slider(parent, label, value, order, callback, o)
		o = o or {}
		local min = o.Min or 0
		local max = o.Max or 100
		local suffix = o.Suffix or "%"
		local function toDisplay(v) return math.floor(v + 0.5) .. suffix end
		local current = math.clamp(value, min, max)

		local row = create("Frame", {
			Size = UDim2.new(1, 0, 0, 52),
			BackgroundTransparency = 1,
			LayoutOrder = order,
			Parent = parent,
		})
		local valueText = create("TextLabel", {
			AnchorPoint = Vector2.new(1, 0),
			Position = UDim2.fromScale(1, 0),
			Size = UDim2.fromOffset(60, 22),
			BackgroundTransparency = 1,
			Text = toDisplay(current),
			TextColor3 = C.Muted,
			TextSize = 13,
			FontFace = Medium,
			TextXAlignment = Enum.TextXAlignment.Right,
			Parent = row,
		})
		create("TextLabel", {
			Size = UDim2.new(1, -65, 0, 22),
			BackgroundTransparency = 1,
			Text = label,
			TextColor3 = C.Text,
			TextSize = 15,
			FontFace = Medium,
			TextXAlignment = Enum.TextXAlignment.Left,
			Parent = row,
		})
		local bar = create("TextButton", {
			Position = UDim2.fromOffset(0, 34),
			Size = UDim2.new(1, 0, 0, 8),
			BackgroundColor3 = C.Control,
			BorderSizePixel = 0,
			Text = "",
			AutoButtonColor = false,
			Parent = row,
		}, { corner(4) })
		local startRatio = (current - min) / (max - min)
		local fill = create("Frame", {
			Size = UDim2.fromScale(startRatio, 1),
			BackgroundColor3 = C.Accent,
			BorderSizePixel = 0,
			Parent = bar,
		}, { corner(4) })
		local thumb = create("Frame", {
			AnchorPoint = Vector2.new(0.5, 0.5),
			Position = UDim2.fromScale(startRatio, 0.5),
			Size = UDim2.fromOffset(15, 15),
			BackgroundColor3 = Color3.new(1, 1, 1),
			BorderSizePixel = 0,
			ZIndex = 3,
			Parent = bar,
		}, { corner(8) })
		table.insert(accentListeners, function(color) fill.BackgroundColor3 = color end)

		local dragging = false
		local fillTween
		local function applyRatio(ratio, fire)
			ratio = math.clamp(ratio, 0, 1)
			current = min + ratio * (max - min)
			if fillTween then fillTween:Cancel() end
			fillTween = TweenService:Create(
				fill,
				TweenInfo.new(0.18, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
				{ Size = UDim2.fromScale(ratio, 1) }
			)
			fillTween:Play()
			tween(thumb, 0.18, { Position = UDim2.fromScale(ratio, 0.5) }, Enum.EasingStyle.Quint)
			valueText.Text = toDisplay(current)
			if fire and callback then task.spawn(callback, math.floor(current + 0.5)) end
		end
		local function update(input)
			applyRatio((input.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, true)
		end
		bar.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 then
				dragging = true
				haptic(0.12)
				tween(thumb, 0.3, { Size = UDim2.fromOffset(20, 20) }, Enum.EasingStyle.Back)
				update(input)
			end
		end)
		UserInputService.InputChanged:Connect(function(input)
			if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then update(input) end
		end)
		UserInputService.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 and dragging then
				dragging = false
				tween(thumb, 0.45, { Size = UDim2.fromOffset(15, 15) }, Enum.EasingStyle.Back)
			end
		end)
		table.insert(searchable, { Name = label:lower(), Object = row })
		return {
			Frame = row,
			Get = function() return math.floor(current + 0.5) end,
			Set = function(_, v)
				applyRatio((math.clamp(v, min, max) - min) / (max - min), true)
			end,
		}
	end

	local function dropdownOption(parent, text, dotColor, onClick)
		local option = create("TextButton", {
			Size = UDim2.new(1, 0, 0, 34),
			BackgroundColor3 = C.PanelHover,
			BackgroundTransparency = 0.4,
			BorderSizePixel = 0,
			Text = "",
			AutoButtonColor = false,
			Parent = parent,
		}, { corner(9) })
		local bar = create("Frame", {
			AnchorPoint = Vector2.new(0, 0.5),
			Position = UDim2.new(0, 6, 0.5, 0),
			Size = UDim2.fromOffset(3, 0),
			BackgroundColor3 = C.Accent,
			BorderSizePixel = 0,
			Parent = option,
		}, { corner(2) })
		table.insert(accentListeners, function(color) bar.BackgroundColor3 = color end)
		local textLeft = 16
		if dotColor then
			textLeft = 34
			create("Frame", {
				AnchorPoint = Vector2.new(0, 0.5),
				Position = UDim2.new(0, 16, 0.5, 0),
				Size = UDim2.fromOffset(10, 10),
				BackgroundColor3 = dotColor,
				BorderSizePixel = 0,
				Parent = option,
			}, { corner(5) })
		end
		local optionLabel = create("TextLabel", {
			Position = UDim2.fromOffset(textLeft, 0),
			Size = UDim2.new(1, -textLeft - 12, 1, 0),
			BackgroundTransparency = 1,
			Text = text,
			TextColor3 = C.Muted,
			TextSize = 14,
			FontFace = Medium,
			TextXAlignment = Enum.TextXAlignment.Left,
			TextTruncate = Enum.TextTruncate.AtEnd,
			Parent = option,
		})
		option.MouseEnter:Connect(function()
			tween(option, 0.16, { BackgroundTransparency = 0, BackgroundColor3 = C.Control })
			tween(optionLabel, 0.16, { TextColor3 = C.Text })
			tween(bar, 0.2, { Size = UDim2.fromOffset(3, 18) }, Enum.EasingStyle.Back)
		end)
		option.MouseLeave:Connect(function()
			tween(option, 0.16, { BackgroundTransparency = 0.4, BackgroundColor3 = C.PanelHover })
			tween(optionLabel, 0.16, { TextColor3 = C.Muted })
			tween(bar, 0.16, { Size = UDim2.fromOffset(3, 0) })
		end)
		option.MouseButton1Click:Connect(function()
			haptic(0.12)
			onClick()
		end)
		return option
	end

	local function dropdown(parent, order, o)
		local options = o.Options or {}
		local function labelOf(c) return type(c) == "table" and c[1] or c end
		local function valueOf(c) return type(c) == "table" and c[2] or c end

		local frame = create("Frame", {
			Size = UDim2.new(1, 0, 0, 43),
			BackgroundColor3 = Color3.fromRGB(40, 43, 49),
			BorderSizePixel = 0,
			ClipsDescendants = true,
			LayoutOrder = order,
			Parent = parent,
		}, { corner(11), stroke(C.Line) })
		local selected = create("TextButton", {
			Size = UDim2.new(1, 0, 0, 43),
			BackgroundTransparency = 1,
			Text = o.Default or o.Placeholder or (options[1] and labelOf(options[1])) or "Select",
			TextColor3 = C.Text,
			TextSize = 14,
			FontFace = Medium,
			TextXAlignment = Enum.TextXAlignment.Left,
			AutoButtonColor = false,
			ZIndex = 2,
			Parent = frame,
		}, { create("UIPadding", { PaddingLeft = UDim.new(0, 13), PaddingRight = UDim.new(0, 35) }) })
		local arrow = create("TextLabel", {
			AnchorPoint = Vector2.new(1, 0.5),
			Position = UDim2.new(1, -10, 0, 21),
			Size = UDim2.fromOffset(24, 24),
			BackgroundTransparency = 1,
			Text = "⌄",
			TextColor3 = C.Muted,
			TextSize = 18,
			ZIndex = 3,
			Parent = frame,
		})
		local list = create("Frame", {
			Position = UDim2.fromOffset(0, 48),
			Size = UDim2.new(1, -16, 0, 0),
			AutomaticSize = Enum.AutomaticSize.Y,
			BackgroundTransparency = 1,
			Parent = frame,
		}, {
			create("UIListLayout", { Padding = UDim.new(0, 4), SortOrder = Enum.SortOrder.LayoutOrder }),
			create("UIPadding", { PaddingLeft = UDim.new(0, 8) }),
		})

		local rowStride = 34 + 4
		local openHeight = 48 + (#options * rowStride) + 6
		local isOpen = false
		local currentValue = nil
		local function close()
			isOpen = false
			tween(arrow, 0.22, { Rotation = 0 })
			tween(frame, 0.28, { Size = UDim2.new(1, 0, 0, 43) }, Enum.EasingStyle.Quint)
		end
		for _, choice in ipairs(options) do
			local lbl, val = labelOf(choice), valueOf(choice)
			dropdownOption(list, lbl, nil, function()
				selected.Text = lbl
				currentValue = val
				close()
				if o.Callback then task.spawn(o.Callback, val) end
			end)
		end
		if o.Default then
			for _, c in ipairs(options) do
				if labelOf(c) == o.Default then currentValue = valueOf(c) end
			end
		end
		selected.MouseButton1Click:Connect(function()
			haptic(0.1)
			isOpen = not isOpen
			tween(arrow, 0.24, { Rotation = isOpen and 180 or 0 })
			tween(frame, 0.34, { Size = UDim2.new(1, 0, 0, isOpen and openHeight or 43) }, Enum.EasingStyle.Back)
		end)
		table.insert(searchable, { Name = (o.Text or selected.Text):lower(), Object = frame })
		return {
			Frame = frame,
			Get = function() return currentValue end,
			Set = function(_, label)
				for _, c in ipairs(options) do
					if labelOf(c) == label then
						selected.Text = label
						currentValue = valueOf(c)
						if o.Callback then task.spawn(o.Callback, currentValue) end
						break
					end
				end
			end,
		}
	end

	if opts.PlayerCard ~= false then
		local playerCard = create("Frame", {
			AnchorPoint = Vector2.new(0, 1),
			Position = UDim2.new(0, 12, 1, -12),
			Size = UDim2.new(1, -24, 0, 64),
			BackgroundColor3 = Color3.fromRGB(50, 54, 61),
			BorderSizePixel = 0,
			Parent = sidebar,
		}, { corner(18), stroke(C.Line) })
		local avatar = create("ImageLabel", {
			Position = UDim2.fromOffset(9, 9),
			Size = UDim2.fromOffset(46, 46),
			BackgroundColor3 = C.Control,
			BorderSizePixel = 0,
			Image = "",
			Parent = playerCard,
		}, { corner(15) })
		task.spawn(function()
			local ok, image = pcall(function()
				return Players:GetUserThumbnailAsync(player.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size150x150)
			end)
			if ok and image then avatar.Image = image end
		end)
		create("TextLabel", {
			Position = UDim2.fromOffset(64, 10),
			Size = UDim2.new(1, -80, 0, 24),
			BackgroundTransparency = 1,
			Text = player.DisplayName,
			TextColor3 = C.Text,
			TextSize = 14,
			FontFace = Medium,
			TextTruncate = Enum.TextTruncate.AtEnd,
			TextXAlignment = Enum.TextXAlignment.Left,
			Parent = playerCard,
		})
		create("TextLabel", {
			Position = UDim2.fromOffset(64, 33),
			Size = UDim2.new(1, -80, 0, 18),
			BackgroundTransparency = 1,
			Text = opts.PlayerTag or "PREMIUM",
			TextColor3 = C.Muted,
			TextSize = 10,
			FontFace = SemiBold,
			TextXAlignment = Enum.TextXAlignment.Left,
			Parent = playerCard,
		})
	end

	if opts.Search ~= false then
		local searchShell = create("Frame", {
			AnchorPoint = Vector2.new(1, 0),
			Position = UDim2.new(1, -150, 0, 22),
			Size = UDim2.fromOffset(34, 34),
			BackgroundColor3 = C.Control,
			BorderSizePixel = 0,
			ClipsDescendants = true,
			Parent = content,
		}, { corner(11), stroke(C.Line) })
		local searchBox = create("TextBox", {
			Position = UDim2.fromOffset(11, 0),
			Size = UDim2.new(1, -43, 1, 0),
			BackgroundTransparency = 1,
			Text = "",
			PlaceholderText = "Search features...",
			PlaceholderColor3 = C.Muted,
			TextColor3 = C.Text,
			TextSize = 13,
			FontFace = Medium,
			ClearTextOnFocus = false,
			TextXAlignment = Enum.TextXAlignment.Left,
			Visible = false,
			Parent = searchShell,
		})
		local searchIcon = create("ImageButton", {
			AnchorPoint = Vector2.new(1, 0.5),
			Position = UDim2.new(1, -9, 0.5, 0),
			Size = UDim2.fromOffset(16, 16),
			BackgroundTransparency = 1,
			Image = Icons.Search,
			ImageColor3 = C.Muted,
			Parent = searchShell,
		})
		local searchFocused = false
		local searchOpen = false
		local function expandSearch(open)
			searchOpen = open
			if open then searchBox.Visible = true end

			tween(searchShell, 0.28, { Size = UDim2.fromOffset(open and 178 or 34, 34) }, Enum.EasingStyle.Back).Completed:Once(function()
				if not searchOpen and not searchFocused and searchBox.Text == "" then
					searchBox.Visible = false
				end
			end)
		end
		searchShell.MouseEnter:Connect(function() expandSearch(true) end)
		searchShell.MouseLeave:Connect(function()
			task.delay(0.06, function()
				if not searchFocused and searchBox.Text == "" then expandSearch(false) end
			end)
		end)
		searchBox.Focused:Connect(function()
			searchFocused = true
			expandSearch(true)
		end)
		searchBox.FocusLost:Connect(function()
			searchFocused = false
			if searchBox.Text == "" then expandSearch(false) end
		end)
		searchIcon.MouseButton1Click:Connect(function()
			searchFocused = true
			expandSearch(true)
			searchBox:CaptureFocus()
		end)
		searchBox:GetPropertyChangedSignal("Text"):Connect(function()
			local query = searchBox.Text:lower()
			for _, item in ipairs(searchable) do
				item.Object.Visible = query == "" or item.Name:find(query, 1, true) ~= nil
			end
		end)
	end

	local reopenDock = create("Frame", {
		AnchorPoint = Vector2.new(1, 0.5),
		Position = UDim2.new(1, -14, 0.5, 0),
		Size = UDim2.fromOffset(0, 0),
		BackgroundColor3 = C.Sidebar,
		BorderSizePixel = 0,
		ClipsDescendants = true,
		Visible = false,
		Parent = backdrop,
	}, {
		corner(26),
		stroke(C.Line),
		create("UIListLayout", {
			FillDirection = Enum.FillDirection.Vertical,
			HorizontalAlignment = Enum.HorizontalAlignment.Center,
			VerticalAlignment = Enum.VerticalAlignment.Center,
			Padding = UDim.new(0, 8),
			SortOrder = Enum.SortOrder.LayoutOrder,
		}),
		create("UIPadding", {
			PaddingTop = UDim.new(0, 9), PaddingBottom = UDim.new(0, 9),
			PaddingLeft = UDim.new(0, 8), PaddingRight = UDim.new(0, 8),
		}),
	})

	local isMenuOpen = true
	local setOpen

	local function dockIcon(name, asset, order)
		local btn = create("TextButton", {
			Size = UDim2.fromOffset(40, 40),
			BackgroundColor3 = C.Control,
			BorderSizePixel = 0,
			Text = "",
			AutoButtonColor = false,
			LayoutOrder = order,
			Parent = reopenDock,
		}, { corner(13), stroke(C.Line) })
		local icon = create("ImageLabel", {
			AnchorPoint = Vector2.new(0.5, 0.5),
			Position = UDim2.fromScale(0.5, 0.5),
			Size = UDim2.fromOffset(18, 18),
			BackgroundTransparency = 1,
			Image = asset,
			ImageColor3 = C.Muted,
			Parent = btn,
		})
		local pop = create("UIScale", { Scale = 1, Parent = btn })
		btn.MouseEnter:Connect(function()
			tween(btn, 0.16, { BackgroundColor3 = C.PanelHover })
			tween(icon, 0.16, { ImageColor3 = C.Accent })
			tween(pop, 0.2, { Scale = 1.12 }, Enum.EasingStyle.Back)
		end)
		btn.MouseLeave:Connect(function()
			tween(btn, 0.16, { BackgroundColor3 = C.Control })
			tween(icon, 0.16, { ImageColor3 = C.Muted })
			tween(pop, 0.2, { Scale = 1 })
		end)
		btn.MouseButton1Click:Connect(function()
			haptic(0.14)
			setOpen(true)
			selectPage(name)
		end)
		return btn
	end

	local DOCK_ROW = 48
	local dockCentre = UDim2.new(1, -14 - 28, 0.5, 0)
	local centre = UDim2.fromScale(0.5, 0.5)
	local function dockFullSize()
		return UDim2.fromOffset(56, math.max(1, dockCount) * DOCK_ROW + 10)
	end
	setOpen = function(value)
		isMenuOpen = value
		if value then
			reopenDock.Visible = true
			tween(reopenDock, 0.2, { Size = UDim2.fromOffset(0, 0) }, Enum.EasingStyle.Quart).Completed:Once(function()
				if isMenuOpen then reopenDock.Visible = false end
			end)
			window.Visible = true
			window.Size = UDim2.fromOffset(WIN_W, WIN_H)
			windowScale.Scale = 0.05
			window.Position = dockCentre
			backdrop.BackgroundTransparency = 1
			tween(backdrop, 0.34, { BackgroundTransparency = 0.88 })
			tween(windowScale, 0.44, { Scale = 1 }, Enum.EasingStyle.Back)
			tween(window, 0.44, { Position = centre }, Enum.EasingStyle.Quint)
		else
			tween(backdrop, 0.32, { BackgroundTransparency = 1 })
			tween(windowScale, 0.3, { Scale = 0.05 }, Enum.EasingStyle.Quint)
			tween(window, 0.3, { Position = dockCentre }, Enum.EasingStyle.Quint).Completed:Once(function()
				if not isMenuOpen then
					window.Visible = false
					windowScale.Scale = 1
					window.Position = centre
				end
			end)
			reopenDock.Visible = true
			reopenDock.Size = UDim2.fromOffset(20, 40)
			tween(reopenDock, 0.36, { Size = dockFullSize() }, Enum.EasingStyle.Back)
		end
	end
	minimizeButton.MouseButton1Click:Connect(function() setOpen(false) end)
	closeButton.MouseEnter:Connect(function()
		tween(closeButton, 0.15, { BackgroundColor3 = C.Danger })
		tween(closeIcon, 0.15, { ImageColor3 = C.Text })
	end)
	closeButton.MouseButton1Click:Connect(function() setOpen(false) end)
	settingsButton.MouseButton1Click:Connect(function()
		if settingsTabName then selectPage(settingsTabName) end
	end)

	local toggleKey = opts.ToggleKey or Enum.KeyCode.K
	local listeningForKey = false
	local toggleKeyCaptureCb = nil
	UserInputService.InputBegan:Connect(function(input)
		if keybindPopupOpen then return end
		if listeningForKey and input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode ~= Enum.KeyCode.Unknown then
			listeningForKey = false
			toggleKey = input.KeyCode
			if toggleKeyCaptureCb then
				local cb = toggleKeyCaptureCb
				toggleKeyCaptureCb = nil
				task.spawn(cb, input.KeyCode.Name, input.KeyCode)
			end
			return
		end
		if input.KeyCode == toggleKey and UserInputService:GetFocusedTextBox() == nil then
			setOpen(not isMenuOpen)
		end
	end)

	if opts.Draggable ~= false then
		local SIDEBAR_OVERHANG = 28
		local draggingWindow, dragStart, windowStart = false
		local function clampRange(v, lo, hi)
			if lo > hi then return (lo + hi) / 2 end
			return math.clamp(v, lo, hi)
		end
		sidebar.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 then
				draggingWindow, dragStart, windowStart = true, input.Position, window.Position
			end
		end)
		UserInputService.InputChanged:Connect(function(input)
			if draggingWindow and input.UserInputType == Enum.UserInputType.MouseMovement then
				local delta = input.Position - dragStart
				local screen = gui.AbsoluteSize
				local size = window.AbsoluteSize
				local halfW, halfH = size.X / 2, size.Y / 2
				local baseX = windowStart.X.Scale * screen.X
				local baseY = windowStart.Y.Scale * screen.Y
				local absX = baseX + windowStart.X.Offset + delta.X
				local absY = baseY + windowStart.Y.Offset + delta.Y
				absX = clampRange(absX, halfW + SIDEBAR_OVERHANG, screen.X - halfW)
				absY = clampRange(absY, halfH, screen.Y - halfH)
				window.Position = UDim2.new(
					windowStart.X.Scale, absX - baseX,
					windowStart.Y.Scale, absY - baseY
				)
			end
		end)
		UserInputService.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 then draggingWindow = false end
		end)
	end

	local Window = {
		Gui = gui,
		Root = window,
		Theme = C,
		Icons = Icons,
	}

	local function buildSection(column, heading, description, iconAsset)
		local holder = section(column, heading, description, iconAsset)
		local order = 2
		local Section = { Holder = holder }
		function Section:AddSeparator()
			order += 1
			separator(holder, order)
		end
		function Section:AddToggle(o)
			order += 1
			return toggle(holder, o.Text or "Toggle", o.Description or "", o.Default, o.Style or "switch", order, o.Keybind or false, o.Callback)
		end
		function Section:AddButton(o)
			order += 1
			return button(holder, o.Text or "Button", order, o.Callback)
		end
		function Section:AddSlider(o)
			order += 1
			return slider(holder, o.Text or "Slider", o.Value or 0, order, o.Callback, o)
		end
		function Section:AddDropdown(o)
			order += 1
			return dropdown(holder, order, o)
		end
		return Section
	end

	function Window:AddTab(name, icon, tabOpts)
		tabOpts = tabOpts or {}
		local pg = makePage(name)
		tabDescriptions[name] = tabOpts.Description or ""
		if tabOpts.Sidebar ~= false then makeTab(name, icon or Icons.Main) end
		if tabOpts.Settings then settingsTabName = name end
		if tabOpts.Dock ~= false then
			dockCount += 1
			dockIcon(name, icon or Icons.Main, dockCount)
		end
		if not activePage then selectPage(name) end

		local Tab = { Name = name, Frame = pg.Frame, Left = pg.Left, Right = pg.Right }
		function Tab:AddSection(side, heading, description, iconAsset)
			local col = pg.Left
			if side == "Right" or side == pg.Right then col = pg.Right end
			return buildSection(col, heading, description, iconAsset)
		end
		function Tab:Select() selectPage(name) end
		return Tab
	end

	function Window:Select(name) selectPage(name) end
	function Window:SetAccent(color)
		C.Accent = color
		for _, fn in ipairs(accentListeners) do fn(color) end
	end
	function Window:SetFont(path) applyFontFamily(path) end
	function Window:SetTextScale(scale) applyTextScale(scale) end
	function Window:GetTextScale() return currentScale end
	function Window:SetToggleKey(key) toggleKey = key end
	function Window:GetToggleKey() return toggleKey end
	function Window:CaptureToggleKey(cb)
		listeningForKey = true
		toggleKeyCaptureCb = cb
	end
	function Window:SetSettingsTab(name) settingsTabName = name end
	function Window:SetOpen(v) setOpen(v and true or false) end
	function Window:Toggle() setOpen(not isMenuOpen) end
	function Window:IsOpen() return isMenuOpen end
	function Window:Destroy()
		gui:Destroy()
	end

	window.Size = UDim2.fromOffset(math.floor(WIN_W * 0.92), math.floor(WIN_H * 0.87))
	window.Position = UDim2.fromScale(0.5, 0.53)
	tween(window, 0.58, {
		Size = UDim2.fromOffset(WIN_W, WIN_H),
		Position = UDim2.fromScale(0.5, 0.5),
	}, Enum.EasingStyle.Back)

	return Window
end

return VelUI
