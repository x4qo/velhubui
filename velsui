		local cardScale = create("UIScale", { Scale = 0.85, Parent = card })
		tween(cardScale, 0.3, { Scale = 1 }, Enum.EasingStyle.Back)
		task.delay(tonumber(o.Duration) or 4, function()
			tween(cardScale, 0.22, { Scale = 0.9 }, Enum.EasingStyle.Quart)
			for _, obj in ipairs(card:GetDescendants()) do
				local props = fadeProps[obj.ClassName]
				if props then
