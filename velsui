function SectionMethods:AddDropdown(config)
	config = normalize(config, "Dropdown")
	local palette = self.Window.Theme
	local options = config.Options or {}
	local row = makeControlRow(self, 61, config.Order)
	addText(row, config.Name, 13, palette.Text, { Size = UDim2.new(1, 0, 0, 20) })
	local selected = new("TextButton", {
		Position = UDim2.fromOffset(0, 24),
		Size = UDim2.new(1, 0, 0, 34),
		BackgroundColor3 = palette.Control,
		BorderSizePixel = 0,
		Text = "",
		TextColor3 = palette.Text,
		TextSize = 13,
		TextXAlignment = Enum.TextXAlignment.Left,
		AutoButtonColor = false,
		Parent = row,
	}, { corner(9), stroke(palette.Line, 0.4) })
	addPadding(selected, 0, 0, 10, 28)
	addText(selected, "⌄", 16, palette.Muted, {
		AnchorPoint = Vector2.new(1, 0),
		Position = UDim2.new(1, 20, 0, 0),
		Size = UDim2.fromOffset(20, 34),
		TextXAlignment = Enum.TextXAlignment.Center,
	})
	local menu = new("Frame", {
		Position = UDim2.new(0, 0, 1, 4),
		Size = UDim2.new(1, 0, 0, 0),
		AutomaticSize = Enum.AutomaticSize.Y,
		BackgroundColor3 = palette.Sidebar,
		BorderSizePixel = 0,
		Visible = false,
		ZIndex = 20,
		Parent = selected,
	}, {
		corner(9), stroke(palette.Line, 0.2),
		new("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder }),
	})
	local value
	local control = {}
	function control:Set(option, silent)
		value = option
		selected.Text = tostring(option or config.Placeholder or "Select...")
		menu.Visible = false
		if not silent then invoke(config.Callback, value) end
	end
	function control:Get() return value end
	function control:Refresh(newOptions)
		options = newOptions or {}
		for _, child in ipairs(menu:GetChildren()) do
			if child:IsA("TextButton") then child:Destroy() end
		end
		for index, option in ipairs(options) do
			local optionValue = option
			local optionButton = new("TextButton", {
				Size = UDim2.new(1, 0, 0, 31),
				BackgroundColor3 = palette.Sidebar,
				BorderSizePixel = 0,
				Text = tostring(optionValue),
				TextColor3 = palette.Muted,
				TextSize = 12,
				AutoButtonColor = false,
				LayoutOrder = index,
				ZIndex = 21,
				Parent = menu,
			})
			optionButton.MouseButton1Click:Connect(function() control:Set(optionValue) end)
			optionButton.MouseEnter:Connect(function()
				tween(optionButton, 0.12, { BackgroundColor3 = palette.Control, TextColor3 = palette.Text })
			end)
			optionButton.MouseLeave:Connect(function()
				tween(optionButton, 0.12, { BackgroundColor3 = palette.Sidebar, TextColor3 = palette.Muted })
			end)
		end
	end
	function control:Destroy() row:Destroy() end
	selected.MouseButton1Click:Connect(function() menu.Visible = not menu.Visible end)
	control:Refresh(options)
	control:Set(config.Default or options[1], true)
	return control
end

function SectionMethods:AddKeybind(config)
	config = normalize(config, "Keybind")
	local palette = self.Window.Theme
	local row = makeControlRow(self, 39, config.Order)
	addText(row, config.Name, 14, palette.Text, { Size = UDim2.new(1, -100, 1, 0) })
	local button = new("TextButton", {
		AnchorPoint = Vector2.new(1, 0.5),
		Position = UDim2.new(1, 0, 0.5, 0),
		Size = UDim2.fromOffset(91, 29),
		BackgroundColor3 = palette.Control,
		BorderSizePixel = 0,
		TextColor3 = palette.Muted,
		TextSize = 12,
		AutoButtonColor = false,
		Parent = row,
	}, { corner(8), stroke(palette.Line, 0.4) })
	local bind = {
		Name = config.Name,
		Key = config.Default or config.Key or Enum.KeyCode.Unknown,
		Mode = config.Mode or "Toggle",
		Callback = config.Callback,
		Listening = false,
		Active = false,
	}
	function bind:Set(key)
		if typeof(key) ~= "EnumItem" or key.EnumType ~= Enum.KeyCode then return false end
		self.Key = key
		button.Text = key == Enum.KeyCode.Unknown and "None" or key.Name
		return true
	end
	function bind:Get() return self.Key end
	function bind:SetMode(mode)
		if mode ~= "Toggle" and mode ~= "Hold" then return false end
		self.Mode = mode
		return true
	end
	function bind:_Pressed()
		if self.Listening then return end
		if self.Mode == "Hold" then
			self.Active = true
		else
			self.Active = not self.Active
		end
		invoke(self.Callback, self.Active, self.Key)
	end
	function bind:_Released()
		if self.Mode == "Hold" and self.Active then
			self.Active = false
			invoke(self.Callback, false, self.Key)
		end
	end
	function bind:Destroy()
		row:Destroy()
		for index, item in ipairs(self.Window.Keybinds) do
			if item == self then table.remove(self.Window.Keybinds, index) break end
		end
	end
	bind.Window = self.Window
	button.MouseButton1Click:Connect(function()
		bind.Listening = true
		button.Text = "Press a key..."
	end)
	local capture
	capture = UserInputService.InputBegan:Connect(function(input)
		if not bind.Listening or input.UserInputType ~= Enum.UserInputType.Keyboard then return end
		bind.Listening = false
		if input.KeyCode == Enum.KeyCode.Escape or input.KeyCode == Enum.KeyCode.Backspace then
			bind:Set(Enum.KeyCode.Unknown)
		else
			bind:Set(input.KeyCode)
		end
	end)
	row.Destroying:Connect(function() capture:Disconnect() end)
	table.insert(self.Window.Keybinds, bind)
	bind:Set(bind.Key)
	return bind
end

