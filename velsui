function SectionMethods:AddSlider(config)
	config = normalize(config, "Slider")
	local palette = self.Window.Theme
	local minimum, maximum = config.Min or 0, config.Max or 100
	if maximum <= minimum then maximum = minimum + 1 end
	local increment = config.Increment or 1
	local row = makeControlRow(self, 52, config.Order)
	addText(row, config.Name, 15, palette.Text, { Size = UDim2.new(1, -60, 0, 22) })
	local valueLabel = addText(row, "", 13, palette.Muted, {
		AnchorPoint = Vector2.new(1, 0),
		Position = UDim2.fromScale(1, 0),
		Size = UDim2.fromOffset(56, 20),
		TextXAlignment = Enum.TextXAlignment.Right,
	})
	local bar = new("TextButton", {
		Position = UDim2.fromOffset(0, 34),
		Size = UDim2.new(1, 0, 0, 7),
		BackgroundColor3 = palette.Control,
		BorderSizePixel = 0,
		Text = "",
		AutoButtonColor = false,
		Parent = row,
	}, { corner(4) })
	local fill = new("Frame", {
		BackgroundColor3 = palette.Accent,
		BorderSizePixel = 0,
		Parent = bar,
	}, { corner(4) })
	local thumb = new("Frame", {
		AnchorPoint = Vector2.new(0.5, 0.5),
		Position = UDim2.fromScale(0, 0.5),
		Size = UDim2.fromOffset(15, 15),
		BackgroundColor3 = Color3.new(1, 1, 1),
		BorderSizePixel = 0,
		ZIndex = 3,
		Parent = bar,
	}, { corner(8) })
	local value = minimum
	self.Window:_RegisterSearch(config.Name, row)
	local control = {}
	function control:Set(number, silent)
		number = math.clamp(number, minimum, maximum)
		number = math.round(number / increment) * increment
		value = number
		local ratio = (value - minimum) / (maximum - minimum)
		tween(fill, 0.18, { Size = UDim2.fromScale(ratio, 1) })
		tween(thumb, 0.18, { Position = UDim2.fromScale(ratio, 0.5) })
		valueLabel.Text = tostring(value) .. (config.Suffix or "")
		if not silent then invoke(config.Callback, value) end
	end
	function control:Get() return value end
	function control:Destroy() row:Destroy() end
	local dragging = false
	local function update(input)
		control:Set(minimum + (maximum - minimum) * math.clamp(
			(input.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1
		))
	end
	bar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true
			haptic(0.12)
			tween(thumb, 0.3, { Size = UDim2.fromOffset(20, 20) }, Enum.EasingStyle.Back)
			update(input)
		end
	end)
	local changed = UserInputService.InputChanged:Connect(function(input)
		if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then update(input) end
	end)
	local ended = UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 and dragging then
			dragging = false
			tween(thumb, 0.45, { Size = UDim2.fromOffset(15, 15) }, Enum.EasingStyle.Back)
		end
	end)
	row.Destroying:Connect(function() changed:Disconnect() ended:Disconnect() end)
	control:Set(config.Default or minimum, true)
	return control
end

