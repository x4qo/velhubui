	end
	function Window:AddKeybindEntry(o)
		o = o or {}
		local entry = {
			key = nil,
			mode = o.Mode or "Toggle",
			name = o.Name or "Keybind",
			external = true,
			getKey = o.GetKey,
			isOn = o.GetActive or o.GetEnabled or function() return false end,
			getMode = o.GetMode,
			flip = function() end,
			setState = function() end,
		}
		table.insert(keybinds, entry)
		if refreshKeybindHud then refreshKeybindHud() end
		return entry
	end
	function Window:Destroy()
		gui:Destroy()
	end
	Window.Unload = Window.Destroy

	window.Size = UDim2.fromOffset(math.floor(WIN_W * 0.92), math.floor(WIN_H * 0.87))
