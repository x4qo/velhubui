	local function setItemFont(item, path)
		if path == "INTER" then
			item.Object.FontFace = (
				item.Weight == Enum.FontWeight.Bold or item.Weight == Enum.FontWeight.SemiBold
			) and SemiBold or Medium
		else
			item.Object.FontFace = Font.new(path, item.Weight, Enum.FontStyle.Normal)
		end
	end

	local function create(className, props, children)
		local object = Instance.new(className)
		local isText = className == "TextLabel" or className == "TextButton" or className == "TextBox"
		if isText then object.FontFace = Medium end
		for key, value in pairs(props or {}) do object[key] = value end
		if isText then
			object.TextScaled = false
			object.TextTransparency = 0
			object.TextStrokeTransparency = 1
			local weight = Enum.FontWeight.SemiBold
			if object.FontFace == Bold then
				weight = Enum.FontWeight.ExtraBold
			elseif object.FontFace == SemiBold then
				weight = Enum.FontWeight.Bold
			elseif object.FontFace == Medium then
				weight = Enum.FontWeight.SemiBold
			end
			local item = { Object = object, BaseSize = object.TextSize, Weight = weight }
			table.insert(textObjects, item)

			object.TextSize = math.max(12, math.round(item.BaseSize * currentScale))
			if currentFontPath then setItemFont(item, currentFontPath) end
		end
		for _, child in ipairs(children or {}) do child.Parent = object end
		return object
	end

	local function applyTextScale(scale)
		currentScale = scale
		for _, item in ipairs(textObjects) do
			if item.Object.Parent then
				item.Object.TextSize = math.max(12, math.round(item.BaseSize * scale))
			end
		end
	end

	local function applyFontFamily(path)
		currentFontPath = (path == "INTER") and nil or path
		for _, item in ipairs(textObjects) do
			if item.Object.Parent then setItemFont(item, path) end
		end
	end

