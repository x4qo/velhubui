	local function selectPage(name)
		if not pages[name] then return end
		for pageName, data in pairs(pages) do data.Frame.Visible = pageName == name end
		for tabName, data in pairs(tabButtons) do
			local selected = tabName == name
			tween(data.Button, 0.2, { BackgroundColor3 = selected and C.Control or C.Sidebar })
			tween(data.Icon, 0.2, { ImageColor3 = selected and C.Accent or C.Muted })
			tween(data.Label, 0.2, { TextColor3 = selected and C.Text or C.Muted })
		end
		activePage = name
		title.Text = name
		subtitle.Text = tabDescriptions[name] or ""

		fadePageIn(pages[name].Frame, 0.5)
		title.TextTransparency = 1
		subtitle.TextTransparency = 1
		tween(title, 0.5, { TextTransparency = 0 }, Enum.EasingStyle.Sine)
		tween(subtitle, 0.5, { TextTransparency = 0 }, Enum.EasingStyle.Sine)
	end

