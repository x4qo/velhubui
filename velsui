function WindowMethods:AddTab(config)
	config = normalize(config, "Tab")
	local palette = self.Theme
	local button = new("TextButton", {
		Size = UDim2.new(1, 0, 0, 45),
		BackgroundColor3 = palette.Sidebar,
		BorderSizePixel = 0,
		Text = "",
		AutoButtonColor = false,
		Parent = self.TabList,
	}, { corner(13) })
	new("ImageLabel", {
		Position = UDim2.fromOffset(14, 13),
		Size = UDim2.fromOffset(18, 18),
		BackgroundTransparency = 1,
		Image = config.Icon or DefaultIcons.Tab,
		ImageColor3 = palette.Muted,
		Parent = button,
	})
	local label = addText(button, config.Name, 15, palette.Muted, {
		Position = UDim2.fromOffset(42, 0),
		Size = UDim2.new(1, -48, 1, 0),
	})
	local page = new("Frame", {
		Name = config.Name,
		Size = UDim2.fromScale(1, 1),
		BackgroundTransparency = 1,
		Visible = false,
		Parent = self.PageHolder,
	})
	local function column(position)
		return new("ScrollingFrame", {
			Position = position,
			Size = UDim2.new(0.5, -6, 1, 0),
			BackgroundTransparency = 1,
			BorderSizePixel = 0,
			ScrollBarThickness = 2,
			ScrollBarImageColor3 = palette.Accent,
			AutomaticCanvasSize = Enum.AutomaticSize.Y,
			CanvasSize = UDim2.new(),
			Parent = page,
		}, {
			new("UIListLayout", { Padding = UDim.new(0, 9), SortOrder = Enum.SortOrder.LayoutOrder }),
			new("UIPadding", {
				PaddingTop = UDim.new(0, 4), PaddingBottom = UDim.new(0, 8),
				PaddingLeft = UDim.new(0, 3), PaddingRight = UDim.new(0, 5),
			}),
		})
	end
	local tab = setmetatable({
		Window = self,
		Name = config.Name,
		Description = config.Description or "",
		Button = button,
		Label = label,
		Icon = button:FindFirstChildOfClass("ImageLabel"),
		Page = page,
		Left = column(UDim2.new()),
		Right = column(UDim2.new(0.5, 6, 0, 0)),
		Sections = {},
	}, { __index = TabMethods })
	table.insert(self.Tabs, tab)
	button.MouseButton1Click:Connect(function() self:SelectTab(tab) end)
	if #self.Tabs == 1 or config.Selected then self:SelectTab(tab) end
	return tab
end

WindowMethods.CreateTab = WindowMethods.AddTab

function WindowMethods:SelectTab(tab)
	if type(tab) == "string" then
		for _, candidate in ipairs(self.Tabs) do
			if candidate.Name == tab then tab = candidate break end
		end
	end
	if type(tab) ~= "table" then return end
	for _, candidate in ipairs(self.Tabs) do
		local active = candidate == tab
		candidate.Page.Visible = active
		tween(candidate.Button, 0.18, {
			BackgroundColor3 = active and self.Theme.Control or self.Theme.Sidebar,
		})
		tween(candidate.Label, 0.18, { TextColor3 = active and self.Theme.Text or self.Theme.Muted })
		tween(candidate.Icon, 0.18, { ImageColor3 = active and self.Theme.Accent or self.Theme.Muted })
	end
	self.ActiveTab = tab
	self.HeaderTitle.Text = tab.Name
	self.HeaderDescription.Text = tab.Description
end

function WindowMethods:Toggle(value)
	if value == nil then value = not self.Open end
	self.Open = value
	if value then
		self.ScreenGui.Enabled = true
		self.Scale.Scale = 0.92
		tween(self.Scale, 0.25, { Scale = 1 }, Enum.EasingStyle.Back)
	else
		tween(self.Scale, 0.16, { Scale = 0.92 }).Completed:Once(function()
			if not self.Open and self.ScreenGui.Parent then self.ScreenGui.Enabled = false end
		end)
	end
end

function WindowMethods:SetToggleKey(key)
	if typeof(key) ~= "EnumItem" or key.EnumType ~= Enum.KeyCode then return false end
	self.ToggleKey = key
	return true
end

function WindowMethods:Destroy()
	for _, connection in ipairs(self.Connections) do connection:Disconnect() end
	self.Connections = {}
	self.ScreenGui:Destroy()
	for index, window in ipairs(self.Library.Windows) do
		if window == self then table.remove(self.Library.Windows, index) break end
	end
end

function TabMethods:AddSection(config)
	config = normalize(config, "Section")
	local side = string.lower(config.Side or "Left")
	local parent = side == "right" and self.Right or self.Left
	local palette = self.Window.Theme
	local holder = new("Frame", {
		Size = UDim2.new(1, -4, 0, 0),
		AutomaticSize = Enum.AutomaticSize.Y,
		BackgroundColor3 = palette.Panel,
		BorderSizePixel = 0,
		LayoutOrder = config.Order or (#self.Sections + 1),
		Parent = parent,
	}, {
		corner(17),
		stroke(palette.Line, 0.42),
		new("UIPadding", {
			PaddingTop = UDim.new(0, 13), PaddingBottom = UDim.new(0, 13),
			PaddingLeft = UDim.new(0, 13), PaddingRight = UDim.new(0, 13),
		}),
		new("UIListLayout", { Padding = UDim.new(0, 7), SortOrder = Enum.SortOrder.LayoutOrder }),
	})
	addText(holder, config.Name, 17, palette.Text, {
		Size = UDim2.new(1, 0, 0, 24),
		FontFace = Bold,
		LayoutOrder = 1,
	})
	local nextOrder = 2
	if config.Description then
		addText(holder, config.Description, 12, palette.Muted, {
			Size = UDim2.new(1, 0, 0, 0),
			AutomaticSize = Enum.AutomaticSize.Y,
			TextWrapped = true,
			LayoutOrder = 2,
		})
		nextOrder = 3
	end
	local section = setmetatable({
		Tab = self,
		Window = self.Window,
		Container = holder,
		Controls = {},
		Order = nextOrder,
	}, { __index = SectionMethods })
	table.insert(self.Sections, section)
	return section
end

TabMethods.CreateSection = TabMethods.AddSection

function SectionMethods:_NextOrder()
	local order = self.Order
	self.Order += 1
	return order
end

function SectionMethods:AddLabel(config)
	config = normalize(config, "")
	local label = addText(self.Container, config.Text or config.Name, config.TextSize or 14, self.Window.Theme.Muted, {
		Size = UDim2.new(1, 0, 0, 0),
		AutomaticSize = Enum.AutomaticSize.Y,
		TextWrapped = config.Wrap ~= false,
		LayoutOrder = config.Order or self:_NextOrder(),
	})
	local control = {}
	function control:Set(text) label.Text = tostring(text) end
	function control:Destroy() label:Destroy() end
	return control
end

function SectionMethods:AddSeparator(config)
	config = config or {}
	local line = new("Frame", {
		Size = UDim2.new(1, 0, 0, 1),
		BackgroundColor3 = self.Window.Theme.Line,
		BorderSizePixel = 0,
		LayoutOrder = config.Order or self:_NextOrder(),
		Parent = self.Container,
	})
	return { Destroy = function() line:Destroy() end }
end

function SectionMethods:AddButton(config)
	config = normalize(config, "Button")
	local palette = self.Window.Theme
	local button = new("TextButton", {
		Size = UDim2.new(1, 0, 0, 40),
		BackgroundColor3 = palette.Sidebar,
		BorderSizePixel = 0,
		Text = config.Name,
		TextColor3 = palette.Text,
		TextSize = 14,
		AutoButtonColor = false,
		LayoutOrder = config.Order or self:_NextOrder(),
		Parent = self.Container,
	}, { corner(11), stroke(palette.Line, 0.35) })
	button.MouseEnter:Connect(function() tween(button, 0.15, { BackgroundColor3 = palette.Control }) end)
	button.MouseLeave:Connect(function() tween(button, 0.15, { BackgroundColor3 = palette.Sidebar }) end)
	button.MouseButton1Click:Connect(function() invoke(config.Callback) end)
	local control = {}
	function control:SetText(text) button.Text = tostring(text) end
	function control:Fire() invoke(config.Callback) end
	function control:Destroy() button:Destroy() end
	return control
end

function SectionMethods:AddToggle(config)
	config = normalize(config, "Toggle")
	local palette = self.Window.Theme
	local row = makeControlRow(self, config.Description and 49 or 36, config.Order)
	addText(row, config.Name, 14, palette.Text, {
		Size = UDim2.new(1, -58, 0, 21),
	})
	if config.Description then
		addText(row, config.Description, 12, palette.Muted, {
			Position = UDim2.fromOffset(0, 23),
			Size = UDim2.new(1, -58, 0, 19),
			TextTruncate = Enum.TextTruncate.AtEnd,
		})
	end
	local track = new("TextButton", {
		AnchorPoint = Vector2.new(1, 0.5),
		Position = UDim2.new(1, 0, 0.5, 0),
		Size = UDim2.fromOffset(43, 25),
		BackgroundColor3 = palette.Control,
		BorderSizePixel = 0,
		Text = "",
		AutoButtonColor = false,
		Parent = row,
	}, { corner(13) })
	local dot = new("Frame", {
		AnchorPoint = Vector2.new(0.5, 0.5),
		Size = UDim2.fromOffset(19, 19),
		BackgroundColor3 = palette.Text,
		BorderSizePixel = 0,
		Parent = track,
	}, { corner(10) })
	local value = config.Default == true
	local control = {}
	function control:Set(state, silent)
		state = not not state
		if value == state then return end
		value = state
		tween(track, 0.18, { BackgroundColor3 = value and palette.Accent or palette.Control })
		tween(dot, 0.22, {
			Position = value and UDim2.new(1, -13, 0.5, 0) or UDim2.new(0, 13, 0.5, 0),
		}, Enum.EasingStyle.Back)
		if not silent then invoke(config.Callback, value) end
	end
	function control:Get() return value end
	function control:Toggle() control:Set(not value) end
	function control:Destroy() row:Destroy() end
	function control:AddKeybind(bindConfig)
		bindConfig = bindConfig or {}
		bindConfig.Name = bindConfig.Name or config.Name
		bindConfig.Callback = bindConfig.Callback or function(active)
			if (bindConfig.Mode or "Toggle") == "Hold" then control:Set(active) else control:Toggle() end
		end
		return self.Section:AddKeybind(bindConfig)
	end
	control.Section = self
	value = not value
	control:Set(config.Default == true, true)
	track.MouseButton1Click:Connect(function() control:Toggle() end)
	if config.Keybind then
		control.Keybind = control:AddKeybind(type(config.Keybind) == "table" and config.Keybind or { Default = config.Keybind })
	end
	return control
end

function SectionMethods:AddSlider(config)
	config = normalize(config, "Slider")
	local palette = self.Window.Theme
	local minimum, maximum = config.Min or 0, config.Max or 100
	if maximum <= minimum then maximum = minimum + 1 end
	local increment = config.Increment or 1
	local row = makeControlRow(self, 51, config.Order)
	addText(row, config.Name, 14, palette.Text, { Size = UDim2.new(1, -60, 0, 20) })
	local valueLabel = addText(row, "", 12, palette.Muted, {
		AnchorPoint = Vector2.new(1, 0),
		Position = UDim2.fromScale(1, 0),
		Size = UDim2.fromOffset(56, 20),
		TextXAlignment = Enum.TextXAlignment.Right,
	})
	local bar = new("TextButton", {
		Position = UDim2.fromOffset(0, 34),
		Size = UDim2.new(1, 0, 0, 7),
		BackgroundColor3 = palette.Control,
		BorderSizePixel = 0,
		Text = "",
		AutoButtonColor = false,
		Parent = row,
	}, { corner(4) })
	local fill = new("Frame", {
		BackgroundColor3 = palette.Accent,
		BorderSizePixel = 0,
		Parent = bar,
	}, { corner(4) })
	local value = minimum
	local control = {}
	function control:Set(number, silent)
		number = math.clamp(number, minimum, maximum)
		number = math.round(number / increment) * increment
		value = number
		local ratio = (value - minimum) / (maximum - minimum)
		tween(fill, 0.12, { Size = UDim2.fromScale(ratio, 1) })
		valueLabel.Text = tostring(value) .. (config.Suffix or "")
		if not silent then invoke(config.Callback, value) end
	end
	function control:Get() return value end
	function control:Destroy() row:Destroy() end
	local dragging = false
	local function update(input)
		control:Set(minimum + (maximum - minimum) * math.clamp(
			(input.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1
		))
	end
	bar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true update(input) end
	end)
	local changed = UserInputService.InputChanged:Connect(function(input)
		if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then update(input) end
	end)
	local ended = UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
	end)
	row.Destroying:Connect(function() changed:Disconnect() ended:Disconnect() end)
	control:Set(config.Default or minimum, true)
	return control
end

function SectionMethods:AddInput(config)
	config = normalize(config, "Input")
	local palette = self.Window.Theme
	local row = makeControlRow(self, 62, config.Order)
	addText(row, config.Name, 13, palette.Text, { Size = UDim2.new(1, 0, 0, 20) })
	local box = new("TextBox", {
		Position = UDim2.fromOffset(0, 24),
		Size = UDim2.new(1, 0, 0, 34),
		BackgroundColor3 = palette.Control,
		BorderSizePixel = 0,
		Text = config.Default or "",
		PlaceholderText = config.Placeholder or "",
		PlaceholderColor3 = palette.Muted,
		TextColor3 = palette.Text,
		TextSize = 13,
		ClearTextOnFocus = config.ClearOnFocus == true,
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = row,
	}, { corner(9), stroke(palette.Line, 0.4) })
	addPadding(box, 0, 0, 10, 10)
	local control = {}
	function control:Set(text, silent)
		box.Text = tostring(text)
		if not silent then invoke(config.Callback, box.Text) end
	end
	function control:Get() return box.Text end
	function control:Destroy() row:Destroy() end
	box.FocusLost:Connect(function(enterPressed)
		if config.Numeric then
			local number = tonumber(box.Text)
			if number then invoke(config.Callback, number, enterPressed) end
		else
			invoke(config.Callback, box.Text, enterPressed)
		end
	end)
	return control
end

