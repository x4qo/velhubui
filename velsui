	for index, bind in ipairs(self.Keybinds) do
		local row = self.KeybindHudRows[bind]
		if bind.Key ~= Enum.KeyCode.Unknown then
			if not row then
				local frame = new("Frame", {
					Size = UDim2.new(1, 0, 0, 30),
					BackgroundTransparency = 1,
					LayoutOrder = index + 1,
					Parent = self.KeybindHud,
				})
				local nameLabel = addText(frame, "", 13, self.Theme.Muted, {
					Size = UDim2.new(1, -105, 1, 0),
					TextTruncate = Enum.TextTruncate.AtEnd,
				})
				local modeLabel = addText(frame, "", 12, self.Theme.Muted, {
					AnchorPoint = Vector2.new(1, 0.5),
					Position = UDim2.new(1, -50, 0.5, 0),
					Size = UDim2.fromOffset(50, 22),
					TextXAlignment = Enum.TextXAlignment.Right,
				})
				local pill = new("Frame", {
					AnchorPoint = Vector2.new(1, 0.5),
					Position = UDim2.new(1, 0, 0.5, 0),
					Size = UDim2.fromOffset(42, 22),
					BackgroundColor3 = self.Theme.Control,
					BorderSizePixel = 0,
					Parent = frame,
				}, { corner(6) })
				local keyLabel = addText(pill, "", 12, self.Theme.Muted, {
					Size = UDim2.fromScale(1, 1),
					FontFace = Bold,
					TextXAlignment = Enum.TextXAlignment.Center,
				})
				row = { Frame = frame, Name = nameLabel, Mode = modeLabel, Pill = pill, Key = keyLabel }
				self.KeybindHudRows[bind] = row
			end
			row.Frame.Visible = true
			row.Name.Text = bind.Name
			row.Mode.Text = bind.Mode
			row.Key.Text = bind.Key.Name
			tween(row.Name, 0.18, { TextColor3 = bind.Active and self.Theme.Text or self.Theme.Muted })
			tween(row.Pill, 0.18, {
				BackgroundColor3 = bind.Active and self.Theme.Accent or self.Theme.Control,
			})
			tween(row.Key, 0.18, {
				TextColor3 = bind.Active and self.Theme.Text or self.Theme.Muted,
			})
			visible += 1
		elseif row then
			row.Frame.Visible = false
		end
	end
	self.KeybindHud.Visible = visible > 0
end

