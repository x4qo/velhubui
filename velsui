function WindowMethods:SelectTab(tab)
	if type(tab) == "string" then
		for _, candidate in ipairs(self.Tabs) do
			if candidate.Name == tab then tab = candidate break end
		end
	end
	if type(tab) ~= "table" then return end
	for _, candidate in ipairs(self.Tabs) do
		local active = candidate == tab
		candidate.Page.Visible = active
		tween(candidate.Button, 0.18, {
			BackgroundColor3 = active and self.Theme.Control or self.Theme.Sidebar,
		})
		tween(candidate.Label, 0.18, { TextColor3 = active and self.Theme.Text or self.Theme.Muted })
		tween(candidate.Icon, 0.18, { ImageColor3 = active and self.Theme.Accent or self.Theme.Muted })
	end
	self.ActiveTab = tab
	self.HeaderTitle.Text = tab.Name
	self.HeaderDescription.Text = tab.Description
	fadeIn(tab.Page, 0.5)
	self.HeaderTitle.TextTransparency = 1
	self.HeaderDescription.TextTransparency = 1
	tween(self.HeaderTitle, 0.5, { TextTransparency = 0 }, Enum.EasingStyle.Sine)
	tween(self.HeaderDescription, 0.5, { TextTransparency = 0 }, Enum.EasingStyle.Sine)
end

function WindowMethods:_Morph(source, startPosition, startSize, endPosition, endSize, duration, endCorner)
	if not source or not source.Parent then return nil end
	if self.ActiveMorph and self.ActiveMorph.Parent then self.ActiveMorph:Destroy() end
	local sourceCorner = source:FindFirstChildOfClass("UICorner")
	local sourceStroke = source:FindFirstChildOfClass("UIStroke")
	local morph = new("Frame", {
		AnchorPoint = Vector2.new(0.5, 0.5),
		Position = UDim2.fromOffset(startPosition.X, startPosition.Y),
		Size = UDim2.fromOffset(startSize.X, startSize.Y),
		BackgroundColor3 = source.BackgroundColor3,
		BackgroundTransparency = source.BackgroundTransparency,
		BorderSizePixel = 0,
		ZIndex = 100,
		Parent = self.ScreenGui,
	}, {
		corner(sourceCorner and sourceCorner.CornerRadius.Offset or 28),
		stroke(
			sourceStroke and sourceStroke.Color or self.Theme.Line,
			sourceStroke and sourceStroke.Transparency or 0.3,
			sourceStroke and sourceStroke.Thickness or 1
		),
	})
	local cornerObject = morph:FindFirstChildOfClass("UICorner")
	tween(cornerObject, duration, { CornerRadius = UDim.new(0, endCorner or 26) }, Enum.EasingStyle.Quint)
	tween(morph, duration, {
		Position = UDim2.fromOffset(endPosition.X, endPosition.Y),
		Size = UDim2.fromOffset(endSize.X, endSize.Y),
	}, Enum.EasingStyle.Quint).Completed:Once(function()
		if self.ActiveMorph == morph then self.ActiveMorph = nil end
		if morph.Parent then morph:Destroy() end
	end)
	self.ActiveMorph = morph
	return morph
end

function WindowMethods:Toggle(value)
	if value == nil then value = not self.Open end
	self.Open = value
	local dockCentre = UDim2.new(1, -42, 0.5, 0)
	local camera = workspace.CurrentCamera
	local viewport = camera and camera.ViewportSize or Vector2.new(1920, 1080)
	local dockSize = Vector2.new(self.DockTargetSize.X.Offset, self.DockTargetSize.Y.Offset)
	local dockPosition = Vector2.new(viewport.X - 42, viewport.Y * 0.5)
	if value then
		local sidebarSize = self.ExpandedSidebarSize or self.Sidebar.AbsoluteSize
		local sidebarPosition = self.ExpandedSidebarPosition or (
			self.Sidebar.AbsolutePosition + self.Sidebar.AbsoluteSize * 0.5
		)
		local morphSource = self.Dock
		morphSource.Size = self.DockTargetSize
		morphSource.Visible = true
		self:_Morph(morphSource, dockPosition, dockSize, sidebarPosition, sidebarSize, 0.44, 28)
		morphSource.Visible = false
		self.Frame.Visible = true
		self.Sidebar.Visible = false
		self.Frame.Size = self.OriginalSize
		self.Frame.Position = dockCentre
		self.Scale.Scale = 0.05
		self.Backdrop.BackgroundTransparency = 1
		tween(self.Backdrop, 0.34, { BackgroundTransparency = self.BackdropTransparency })
		tween(self.Scale, 0.44, { Scale = 1 }, Enum.EasingStyle.Back)
		tween(self.Frame, 0.44, { Position = self.OriginalPosition }, Enum.EasingStyle.Quint)
		task.delay(0.32, function()
			if self.Open and self.Sidebar.Parent then
				self.Sidebar.Visible = true
				fadeIn(self.Sidebar, 0.18)
			end
		end)
	else
		local expandedSize = self.Sidebar.AbsoluteSize
		local expandedPosition = self.Sidebar.AbsolutePosition + expandedSize * 0.5
		self.ExpandedSidebarSize = expandedSize
		self.ExpandedSidebarPosition = expandedPosition
		self:_Morph(self.Sidebar, expandedPosition, expandedSize, dockPosition, dockSize, 0.36, 26)
		self.Sidebar.Visible = false
		tween(self.Backdrop, 0.32, { BackgroundTransparency = 1 })
		tween(self.Scale, 0.3, { Scale = 0.05 }, Enum.EasingStyle.Quint)
		tween(self.Frame, 0.3, { Position = dockCentre }, Enum.EasingStyle.Quint).Completed:Once(function()
			if not self.Open and self.Frame.Parent then
				self.Frame.Visible = false
				self.Scale.Scale = 1
				self.Frame.Position = self.OriginalPosition
				self.Sidebar.Visible = true
			end
		end)
		self.Dock.Visible = false
		task.delay(0.34, function()
			if not self.Open and self.Dock.Parent then
				self.Dock.Size = self.DockTargetSize
				self.DockScale.Scale = 0.72
				self.Dock.Visible = true
				tween(self.DockScale, 0.18, { Scale = 1 }, Enum.EasingStyle.Back)
			end
		end)
	end
end

function WindowMethods:SetToggleKey(key)
	if typeof(key) ~= "EnumItem" or key.EnumType ~= Enum.KeyCode then return false end
	self.ToggleKey = key
	return true
end

function WindowMethods:SetAccent(color)
	if typeof(color) ~= "Color3" then return false end
	local previous = self.Theme.Accent
	self.Theme.Accent = color
	for _, object in ipairs(self.ScreenGui:GetDescendants()) do
		pcall(function()
			if object.BackgroundColor3 == previous then object.BackgroundColor3 = color end
		end)
		pcall(function()
			if object.ImageColor3 == previous then object.ImageColor3 = color end
		end)
		pcall(function()
			if object.TextColor3 == previous then object.TextColor3 = color end
		end)
	end
	return true
end

function WindowMethods:SetTextScale(scale)
	if type(scale) ~= "number" then return false end
	scale = math.clamp(scale, 0.7, 1.5)
	for _, object in ipairs(self.ScreenGui:GetDescendants()) do
		if object:IsA("TextLabel") or object:IsA("TextButton") or object:IsA("TextBox") then
			local base = object:GetAttribute("AuroraBaseTextSize")
			if not base then
				base = object.TextSize
				object:SetAttribute("AuroraBaseTextSize", base)
			end
			object.TextSize = math.max(8, math.round(base * scale))
		end
	end
	return true
end

function WindowMethods:SetFont(path)
	if type(path) ~= "string" then return false end
	for _, object in ipairs(self.ScreenGui:GetDescendants()) do
		if object:IsA("TextLabel") or object:IsA("TextButton") or object:IsA("TextBox") then
			pcall(function()
				local weight = object.FontFace.Weight
				if path == "INTER" then
					object.FontFace = (
						weight == Enum.FontWeight.Bold or weight == Enum.FontWeight.ExtraBold
					) and SemiBold or Medium
				else
					object.FontFace = Font.new(path, weight, Enum.FontStyle.Normal)
				end
			end)
		end
	end
	return true
end

function WindowMethods:Destroy()
	for _, connection in ipairs(self.Connections) do connection:Disconnect() end
	self.Connections = {}
	self.ScreenGui:Destroy()
	for index, window in ipairs(self.Library.Windows) do
		if window == self then table.remove(self.Library.Windows, index) break end
	end
end

