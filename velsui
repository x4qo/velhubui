	promptKeybind = function(gear, entry)
		if keybindPopupOpen and keybindEntry == entry then
			hideKeybind()
			return
		end
		keybindEntry = entry
		keybindListening = false
		refreshKeyButton()
		entry.mode = entry.mode or "Toggle"
		highlightMode(entry.mode, false)
		keybindPop.Size = UDim2.fromOffset(186, BASE_HEIGHT)
		local rel = gear.AbsolutePosition - window.AbsolutePosition
		keybindPop.Position = UDim2.fromOffset(rel.X + gear.AbsoluteSize.X, rel.Y + gear.AbsoluteSize.Y + 6)
		keybindPopupOpen = true
		keybindShade.Visible = true
		keybindPop.Visible = true
		keybindScale.Scale = 0
		tween(keybindScale, 0.34, { Scale = 1 }, Enum.EasingStyle.Back)
	end
	keybindKeyButton.MouseButton1Click:Connect(function()
		haptic(0.1)
		keybindListening = true
		refreshKeyButton()
	end)
	keybindKeyButton.MouseEnter:Connect(function()
		if not keybindListening then tween(keybindKeyButton, 0.15, { BackgroundColor3 = C.PanelHover }) end
	end)
	keybindKeyButton.MouseLeave:Connect(function() tween(keybindKeyButton, 0.15, { BackgroundColor3 = C.Control }) end)
	keybindKeyButton.MouseButton2Click:Connect(function()
		haptic(0.1)
		if keybindEntry then keybindEntry.key = nil end
		keybindListening = false
		refreshKeyButton()
		if refreshKeybindHud then refreshKeybindHud() end
	end)
	keybindShade.MouseButton1Click:Connect(function() hideKeybind() end)

	UserInputService.InputBegan:Connect(function(input, processed)
		if input.UserInputType ~= Enum.UserInputType.Keyboard or input.KeyCode == Enum.KeyCode.Unknown then
			return
		end
		if keybindListening and keybindEntry then
			if input.KeyCode ~= Enum.KeyCode.Escape then
				keybindEntry.key = input.KeyCode
			end
			keybindListening = false
			refreshKeyButton()
			if refreshKeybindHud then refreshKeybindHud() end
			return
		end
		if keybindPopupOpen or processed or UserInputService:GetFocusedTextBox() then return end
		for _, kb in ipairs(keybinds) do
			if kb.key == input.KeyCode then
				haptic(0.16)
				if kb.mode == "Hold" then kb.setState(true) else kb.flip() end
			end
		end
	end)
	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType ~= Enum.UserInputType.Keyboard then return end
		for _, kb in ipairs(keybinds) do
			if kb.mode == "Hold" and kb.key == input.KeyCode then
				kb.setState(false)
			end
		end
	end)

