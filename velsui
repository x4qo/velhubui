local DEFAULT_TEXT_SCALE = 1.035

local function new(className, properties, children)
	local object = Instance.new(className)
	local isText = object:IsA("TextLabel") or object:IsA("TextButton") or object:IsA("TextBox")
	if isText then
		object.FontFace = Medium
	end
	for key, value in pairs(properties or {}) do
		object[key] = value
	end
	for _, child in ipairs(children or {}) do
		child.Parent = object
	end
	if isText then
		object.TextScaled = false
		object.TextTransparency = 0
		object.TextStrokeTransparency = 1
		local baseSize = object.TextSize
		object:SetAttribute("AuroraBaseTextSize", baseSize)
		object.TextSize = math.max(12, math.round(baseSize * DEFAULT_TEXT_SCALE))
	end
	return object
end

local function corner(radius)
	return new("UICorner", { CornerRadius = UDim.new(0, radius) })
end

local function stroke(color, transparency, thickness)
	return new("UIStroke", {
		Color = color,
		Transparency = transparency or 0,
		Thickness = thickness or 1,
		ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
	})
end

local function tween(object, duration, properties, style)
	local animation = TweenService:Create(object, TweenInfo.new(
		duration or 0.18,
		style or Enum.EasingStyle.Quint,
		Enum.EasingDirection.Out
	), properties)
	animation:Play()
	return animation
end

local function haptic(strength)
	task.spawn(function()
		pcall(function()
			if HapticService:IsVibrationSupported(Enum.UserInputType.Gamepad1) then
				HapticService:SetMotor(
					Enum.UserInputType.Gamepad1,
					Enum.VibrationMotor.Small,
					strength or 0.18
				)
				task.wait(0.035)
				HapticService:SetMotor(Enum.UserInputType.Gamepad1, Enum.VibrationMotor.Small, 0)
			end
		end)
	end)
end

local fadeProperties = {
	TextLabel = { "BackgroundTransparency", "TextTransparency", "TextStrokeTransparency" },
	TextButton = { "BackgroundTransparency", "TextTransparency", "TextStrokeTransparency" },
	TextBox = { "BackgroundTransparency", "TextTransparency", "TextStrokeTransparency" },
	ImageLabel = { "BackgroundTransparency", "ImageTransparency" },
	ImageButton = { "BackgroundTransparency", "ImageTransparency" },
	Frame = { "BackgroundTransparency" },
	ScrollingFrame = { "BackgroundTransparency" },
	UIStroke = { "Transparency" },
}

local fadeTargets = setmetatable({}, { __mode = "k" })

local function fadeIn(container, duration)
	for _, object in ipairs(container:GetDescendants()) do
		local properties = fadeProperties[object.ClassName]
		if properties then
			local targets = fadeTargets[object]
			if not targets then
				targets = {}
				for _, property in ipairs(properties) do targets[property] = object[property] end
				fadeTargets[object] = targets
			end
			local goal = {}
			for property, target in pairs(targets) do
				object[property] = 1
				goal[property] = target
			end
			tween(object, duration or 0.5, goal, Enum.EasingStyle.Sine)
		end
	end
end

local function merge(base, additions)
	local result = {}
	for key, value in pairs(base or {}) do result[key] = value end
	for key, value in pairs(additions or {}) do result[key] = value end
	return result
end

local function invoke(callback, ...)
	if callback then
		task.spawn(function(...)
			pcall(callback, ...)
		end, ...)
	end
end

local random = Random.new()
local characters = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"

local function randomString(length)
	local result = table.create(length)
	for index = 1, length do
		local position = random:NextInteger(1, #characters)
		result[index] = string.sub(characters, position, position)
	end
	return table.concat(result)
end

local function resolveParent()
	if type(gethui) ~= "function" then return nil end
	local success, parent = pcall(gethui)
	if not success then return nil end
	if typeof(parent) ~= "Instance" then return nil end
	return parent
end

local function normalize(config, fallbackName)
	if type(config) == "string" then return { Name = config } end
	config = config or {}
	if fallbackName and config.Name == nil then config.Name = fallbackName end
	return config
end

local function addPadding(parent, top, bottom, left, right)
	return new("UIPadding", {
		PaddingTop = UDim.new(0, top),
		PaddingBottom = UDim.new(0, bottom),
		PaddingLeft = UDim.new(0, left),
		PaddingRight = UDim.new(0, right),
		Parent = parent,
	})
end

local function addText(parent, text, size, color, properties)
	return new("TextLabel", merge({
		Size = UDim2.new(1, 0, 0, size + 7),
		BackgroundTransparency = 1,
		Text = text or "",
		TextColor3 = color,
		TextSize = size,
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = parent,
	}, properties))
end

local function makeControlRow(section, height, order)
	return new("Frame", {
		Size = UDim2.new(1, 0, 0, height),
		BackgroundTransparency = 1,
		LayoutOrder = order or section:_NextOrder(),
		Parent = section.Container,
	})
end

