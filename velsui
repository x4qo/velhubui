		ScrollingFrame = { "BackgroundTransparency" },
		UIStroke = { "Transparency" },
	}
	local fadeTargets = setmetatable({}, { __mode = "k" })
	local function fadePageIn(page, duration)
		for _, obj in ipairs(page:GetDescendants()) do
			local props = fadeProps[obj.ClassName]
			if props then
				local targets = fadeTargets[obj]
				if not targets then
					targets = {}
					for _, p in ipairs(props) do targets[p] = obj[p] end
					fadeTargets[obj] = targets
				end
				local goal = {}
				for p, target in pairs(targets) do
					obj[p] = 1
					goal[p] = target
				end
				tween(obj, duration, goal, Enum.EasingStyle.Sine)
			end
		end
	end

