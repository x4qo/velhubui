	refreshKeybindHud = function()
		local visible = 0
		for i, entry in ipairs(keybinds) do
			local row = hudRows[entry]
			local key = entry.key
			if entry.getKey then
				local ok, k = pcall(entry.getKey)
				key = ok and k or nil
			end
			if key then
				if not row then
					row = createHudRow(2 + i)
					hudRows[entry] = row
				end
				local mode = entry.mode
				if entry.getMode then
					local ok, m = pcall(entry.getMode)
					if ok and m then mode = m end
				end
				row.Frame.Visible = true
				row.Name.Text = entry.name
				row.Mode.Text = (mode == "Hold") and "Hold" or "Toggle"
				row.Key.Text = key.Name
				local on = false
				if entry.isOn then
					local ok, v = pcall(entry.isOn)
					on = ok and v or false
				end
				tween(row.Name, 0.18, { TextColor3 = on and C.Text or C.Muted })
				tween(row.Pill, 0.18, { BackgroundColor3 = on and C.Accent or PILL_OFF })
				tween(row.Key, 0.18, { TextColor3 = on and Color3.new(1, 1, 1) or C.Muted })
