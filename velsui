	local function slider(parent, label, value, order, callback, o)
		o = o or {}
		local min = o.Min or 0
		local max = o.Max or 100
		local suffix = o.Suffix or "%"
		local decimals = tonumber(o.Rounding) or tonumber(o.Decimals) or 0
		local function roundTo(v)
			if decimals <= 0 then return math.floor(v + 0.5) end
			local m = 10 ^ decimals
			return math.floor(v * m + 0.5) / m
		end
		local function toDisplay(v)
			if decimals > 0 then return string.format("%." .. decimals .. "f", v) .. suffix end
			return math.floor(v + 0.5) .. suffix
		end
		local current = math.clamp(value, min, max)

		local row = create("Frame", {
			Size = UDim2.new(1, 0, 0, 52),
			BackgroundTransparency = 1,
			LayoutOrder = order,
