		if keybindListening then
			keybindKeyButton.Text = "Press a key…"
		elseif keybindEntry and keybindEntry.key then
			keybindKeyButton.Text = keybindEntry.key.Name
		else
			keybindKeyButton.Text = "Unbound"
		end
		keybindKeyButton.TextColor3 = keybindListening and C.Accent or C.Text
