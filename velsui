	function Window:GetFonts()
		local names = {}
		for name in pairs(Fonts) do names[#names + 1] = name end
		table.sort(names)
		return names
	end
	function Window:SetKeybindPanelEnabled(on)
		keybindPanelEnabled = on and true or false
