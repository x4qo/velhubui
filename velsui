			local delta = input.Position - dragStart
			frame.Position = UDim2.new(
				startPosition.X.Scale, startPosition.X.Offset + delta.X,
				startPosition.Y.Scale, startPosition.Y.Offset + delta.Y
			)
		end
	end))
	table.insert(window.Connections, UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
	end))
	table.insert(window.Connections, UserInputService.InputBegan:Connect(function(input, processed)
		if processed or UserInputService:GetFocusedTextBox() then return end
		for _, bind in ipairs(window.Keybinds) do
			if bind.Listening then return end
		end
		if input.KeyCode == window.ToggleKey then
			window:Toggle()
			return
		end
		for _, bind in ipairs(window.Keybinds) do
			if bind.Key == input.KeyCode then bind:_Pressed() end
		end
	end))
	table.insert(window.Connections, UserInputService.InputEnded:Connect(function(input)
		for _, bind in ipairs(window.Keybinds) do
			if bind.Key == input.KeyCode then bind:_Released() end
		end
	end))

	if config.IntroAnimation ~= false then
		frame.Size = UDim2.fromOffset(
			math.max(320, size.X.Offset - 60),
			math.max(260, size.Y.Offset - 70)
		)
		frame.Position = UDim2.new(
			window.OriginalPosition.X.Scale,
			window.OriginalPosition.X.Offset,
			window.OriginalPosition.Y.Scale + 0.03,
			window.OriginalPosition.Y.Offset
		)
		tween(frame, 0.58, {
			Size = size,
			Position = window.OriginalPosition,
		}, Enum.EasingStyle.Back)
	end

	table.insert(self.Windows, window)
	return window
end

