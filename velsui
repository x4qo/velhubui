function Library:AddWindow(config)
	config = normalize(config, "Aurora")
	local palette = merge(Theme, config.Theme)
	local parent = resolveParent()
	if not parent then return nil end
	local guiName = randomString(32)

	local screen = new("ScreenGui", {
		Name = guiName,
		IgnoreGuiInset = config.IgnoreGuiInset ~= false,
		ResetOnSpawn = config.ResetOnSpawn == true,
		ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
		Parent = parent,
	})
	local backdrop = new("Frame", {
		Size = UDim2.fromScale(1, 1),
		BackgroundColor3 = Color3.fromRGB(12, 13, 15),
		BackgroundTransparency = config.BackdropTransparency or 0.88,
		BorderSizePixel = 0,
		Parent = screen,
	})
	local size = config.Size or UDim2.fromOffset(780, 540)
	local frame = new("Frame", {
		AnchorPoint = Vector2.new(0.5, 0.5),
		Position = config.Position or UDim2.fromScale(0.5, 0.5),
		Size = size,
		BackgroundColor3 = palette.Background,
		BorderSizePixel = 0,
		Parent = backdrop,
	}, { corner(22), stroke(palette.Line, 0.35) })
	local scale = new("UIScale", { Scale = 1, Parent = frame })

	local sidebar = new("Frame", {
		Position = UDim2.fromOffset(16, 16),
		Size = UDim2.new(0, 190, 1, -32),
		BackgroundColor3 = palette.Sidebar,
		BorderSizePixel = 0,
		ClipsDescendants = true,
		Parent = frame,
	}, { corner(18), stroke(palette.Line, 0.4) })

	local brand = new("Frame", {
		Position = UDim2.fromOffset(16, 15),
		Size = UDim2.new(1, -32, 0, 48),
		BackgroundTransparency = 1,
		Parent = sidebar,
	})
	local logo = new("Frame", {
		Size = UDim2.fromOffset(42, 42),
		BackgroundColor3 = palette.Accent,
		BorderSizePixel = 0,
		Parent = brand,
	}, { corner(13) })
	addText(logo, config.LogoText or string.sub(config.Title or config.Name or "A", 1, 1), 22, palette.Text, {
		Size = UDim2.fromScale(1, 1),
		FontFace = Bold,
		TextXAlignment = Enum.TextXAlignment.Center,
	})
	addText(brand, config.Title or config.Name, 17, palette.Text, {
		Position = UDim2.fromOffset(52, 1),
		Size = UDim2.new(1, -52, 0, 22),
		FontFace = Bold,
	})
	addText(brand, config.Subtitle or "UI Library", 12, palette.Muted, {
		Position = UDim2.fromOffset(52, 23),
		Size = UDim2.new(1, -52, 0, 18),
	})

	local tabList = new("Frame", {
		Position = UDim2.fromOffset(12, 78),
		Size = UDim2.new(1, -24, 1, -92),
		BackgroundTransparency = 1,
		Parent = sidebar,
	}, {
		new("UIListLayout", {
			Padding = UDim.new(0, 7),
			SortOrder = Enum.SortOrder.LayoutOrder,
		}),
	})

	local content = new("Frame", {
		Position = UDim2.fromOffset(222, 0),
		Size = UDim2.new(1, -222, 1, 0),
		BackgroundTransparency = 1,
		Parent = frame,
	})
	local headerTitle = addText(content, "", 23, palette.Text, {
		Position = UDim2.fromOffset(24, 22),
		Size = UDim2.new(1, -150, 0, 30),
		FontFace = Bold,
	})
	local headerDescription = addText(content, "", 13, palette.Muted, {
		Position = UDim2.fromOffset(24, 51),
		Size = UDim2.new(1, -150, 0, 20),
	})
	local pages = new("Frame", {
		Position = UDim2.fromOffset(20, 82),
		Size = UDim2.new(1, -40, 1, -100),
		BackgroundTransparency = 1,
		ClipsDescendants = true,
		Parent = content,
	})

	local window = setmetatable({
		Library = self,
		ScreenGui = screen,
		Frame = frame,
		Scale = scale,
		Sidebar = sidebar,
		TabList = tabList,
		PageHolder = pages,
		HeaderTitle = headerTitle,
		HeaderDescription = headerDescription,
		Theme = palette,
		Tabs = {},
		Connections = {},
		Keybinds = {},
		Open = true,
		ToggleKey = config.ToggleKey or Enum.KeyCode.RightShift,
	}, { __index = WindowMethods })

	local function topButton(offset, text, hover)
		local button = new("TextButton", {
			AnchorPoint = Vector2.new(1, 0),
			Position = UDim2.new(1, offset, 0, 20),
			Size = UDim2.fromOffset(36, 36),
			BackgroundColor3 = palette.Control,
			BorderSizePixel = 0,
			Text = text,
			TextColor3 = palette.Muted,
			TextSize = 19,
			AutoButtonColor = false,
			Parent = content,
		}, { corner(11) })
		button.MouseEnter:Connect(function()
			tween(button, 0.15, { BackgroundColor3 = hover or palette.PanelHover, TextColor3 = palette.Text })
		end)
		button.MouseLeave:Connect(function()
			tween(button, 0.15, { BackgroundColor3 = palette.Control, TextColor3 = palette.Muted })
		end)
		return button
	end

	local minimize = topButton(-58, "−")
	local close = topButton(-16, "×", palette.Danger)
	minimize.MouseButton1Click:Connect(function() window:Toggle() end)
	close.MouseButton1Click:Connect(function()
		if config.CloseDestroys then window:Destroy() else window:Toggle(false) end
	end)

	local dragging, dragStart, startPosition
	table.insert(window.Connections, sidebar.InputBegan:Connect(function(input)
		if config.Draggable ~= false and input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging, dragStart, startPosition = true, input.Position, frame.Position
		end
	end))
	table.insert(window.Connections, UserInputService.InputChanged:Connect(function(input)
		if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
			local delta = input.Position - dragStart
			frame.Position = UDim2.new(
				startPosition.X.Scale, startPosition.X.Offset + delta.X,
				startPosition.Y.Scale, startPosition.Y.Offset + delta.Y
			)
		end
	end))
	table.insert(window.Connections, UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
	end))
	table.insert(window.Connections, UserInputService.InputBegan:Connect(function(input, processed)
		if processed or UserInputService:GetFocusedTextBox() then return end
		if input.KeyCode == window.ToggleKey then
			window:Toggle()
			return
		end
		for _, bind in ipairs(window.Keybinds) do
			if bind.Key == input.KeyCode then bind:_Pressed() end
		end
	end))
	table.insert(window.Connections, UserInputService.InputEnded:Connect(function(input)
		for _, bind in ipairs(window.Keybinds) do
			if bind.Key == input.KeyCode then bind:_Released() end
		end
	end))

	table.insert(self.Windows, window)
	return window
end

